# Crate Configuration
TZ=Europe/Madrid
PUID=1000
PGID=1000
DOMAIN=example.com
LANGUAGE=es

# Directories
DATA_DIR=./data
MEDIA_DIR=./media

# Ports
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TIDARR_PORT=8484
CRATE_API_PORT=8585
CRATE_UI_PORT=8580
NGINX_PORT=8090

# Cloudflare
CF_DNS_API_TOKEN=

# Service credentials
TIDARR_PASSWORD=

# External APIs
LASTFM_APIKEY=
LASTFM_API_SECRET=
FANART_API_KEY=
SPOTIFY_ID=
SPOTIFY_SECRET=
SETLISTFM_API_KEY=
TIDAL_COUNTRY_CODE=ES

# PostgreSQL superuser bootstrap
POSTGRES_SUPERUSER_USER=crate
POSTGRES_SUPERUSER_PASSWORD=
POSTGRES_SUPERUSER_DB=crate

# PostgreSQL app user
CRATE_POSTGRES_USER=crate
CRATE_POSTGRES_PASSWORD=
CRATE_POSTGRES_DB=crate

# Auth
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DEFAULT_ADMIN_PASSWORD=admin

# Optional local-dev Soulseek credentials.
# Keep these separate from the main/prod Soulseek account so a local slskd
# does not kick the production instance off the network.
DEV_SLSKD_SLSK_USERNAME=
DEV_SLSKD_SLSK_PASSWORD=
