.vite/
tsconfig.tsbuildinfo

# iOS project (Capacitor). We track the project shell; build artefacts,
# generated web assets, and user-local Xcode state are excluded by
# ios/.gitignore inside the native project.

# Android project (Capacitor). We DO track the project shell — manifest,
# gradle config, resources, icons — so CI can build a debug APK and the
# project stays reproducible across contributors. We exclude build
# artefacts and machine-local files below.
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/capacitor-cordova-android-plugins/build/
android/local.properties
android/*.iml
android/app/*.iml
android/app/release/
android/app/src/main/assets/public/
# Capacitor regenerates these on `cap sync` from the web bundle — no
# need to commit them (they're the compiled Listen dist copied into
# the native project).
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
