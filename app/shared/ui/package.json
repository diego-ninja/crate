{
  "name": "@crate/ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "sideEffects": [
    "tokens/*.css"
  ],
  "exports": {
    "./tokens/*": "./tokens/*",
    "./lib/*": {
      "types": "./lib/*.ts",
      "default": "./lib/*.ts"
    },
    "./primitives/*": {
      "types": "./primitives/*.tsx",
      "default": "./primitives/*.tsx"
    },
    "./shadcn/*": {
      "types": "./shadcn/*.tsx",
      "default": "./shadcn/*.tsx"
    },
    "./composites/*": {
      "types": "./composites/*.tsx",
      "default": "./composites/*.tsx"
    },
    "./domain/*": {
      "types": "./domain/*.tsx",
      "default": "./domain/*.tsx"
    },
    "./charts/*": {
      "types": "./charts/*.ts",
      "default": "./charts/*.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup lib/*.ts primitives/*.tsx shadcn/*.tsx composites/*.tsx domain/**/*.tsx domain/**/*.ts --format esm --dts --outdir dist --external react --external react-dom --external react-router --external radix-ui --external lucide-react --external class-variance-authority --external clsx --external tailwind-merge --external qrcode"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": ">=0.400.0",
    "radix-ui": "^1.0.0",
    "tailwind-merge": "^3.0.0"
  }
}
